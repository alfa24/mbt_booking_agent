TELEGRAM_BOT_TOKEN=
BOT_USERNAME=mbt_house_booking_bot
ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
LLM_MODEL=openrouter/qwen/qwen3-max-thinking
SYSTEM_PROMPT=
LOG_LEVEL=INFO

# Backend API URL (для Docker-контейнеров)
BACKEND_API_URL=http://backend:8000

# Frontend API URL (для браузера, должен быть доступен с хоста)
# Для Docker: http://backend:8000/api/v1
# Для разработки с хоста: http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DATABASE_URL=postgresql+asyncpg://booking:booking@localhost/booking
BACKEND_LOG_LEVEL=INFO

# Database (for docker-compose)
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_DB=booking
