FROM node:20-alpine AS deps
WORKDIR /app
RUN corepack enable
COPY web/package.json web/package-lock.json ./
RUN npm ci

# Development stage
FROM deps AS dev
WORKDIR /app

COPY web/ .

ENV NODE_ENV=development
ENV PATH=/app/node_modules/.bin:$PATH

EXPOSE 3000

CMD ["npm", "run", "dev"]

FROM node:20-alpine AS builder
WORKDIR /app
RUN corepack enable
COPY --from=deps /app/node_modules ./node_modules
COPY web/ .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

RUN corepack enable

# Copy built artifacts with proper ownership
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD node -e "const http = require('http'); const opts = {hostname: 'localhost', port: 3000, path: '/', timeout: 3000}; http.get(opts, (res) => { process.exit(res.statusCode < 400 ? 0 : 1); }).on('error', () => process.exit(1))" || exit 1

CMD ["node", "server.js"]
